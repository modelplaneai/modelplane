      "text": "attributes: {...}                # env-level\nprovisioning:\n  mode: dra | device-plugin | hybrid\n\nscheduler:\n  type: managed-kueue            # default\n                                 # or: kueue | kai | volcano | none\nbackend:\n  type: managed-kserve           # default\n                                 # or: kserve | dynamo | raw-vllm\n  version: v0.18.0\n\nnodePools:\n  - name: gpu-h200\n    nodeSelector: {...}\n    nodeAttributes: {...}\n    deviceAttributes: {...}\n\ncluster:\n  source: gcp | aws | byo\n  ...\n",
