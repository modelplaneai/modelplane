      "updated": 1778116756182,
      "link": null,
      "locked": false,
      "text": "clusterClaim:                  # env-level attrs\n  selector: {matchLabels | matchAttributes | cel}\n\ndeviceClaim:                   # node + device attrs (uniform)\n  requests:\n    - name: gpu\n      count: N\n      perNode: M\n      selector:\n        matchLabels: {...}     # primary path\n        matchAttributes: {...} # DRA break-glass\n\nrequiredEngineFeatures: [...]  # vs cluster's KServeBackend\n\n# parallelism, roles (xPyD), engine, scaling, adapters\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "clusterClaim:                  # env-level attrs\n  selector: {matchLabels | matchAttributes | cel}\n\ndeviceClaim:                   # node + device attrs (uniform)\n  requests:\n    - name: gpu\n      count: N\n      perNode: M\n      selector:\n        matchLabels: {...}     # primary path\n        matchAttributes: {...} # DRA break-glass\n\nrequiredEngineFeatures: [...]  # vs cluster's KServeBackend\n\n# parallelism, roles (xPyD), engine, scaling, adapters\n",
      "autoResize": true,
      "lineHeight": 1.25
