[5.009, "o", "\r\n\u001b[2m# ML TEAM edits the SAME qwen-demo — more replicas and a selector asking for >= 35Gi. The L4 (24Gi) no longer qualifies:\u001b[0m\r\n"]
[2.009, "o", "\u001b[1;32m$ \u001b[0m\u001b[1m"]
[0.000, "o", "m"]
