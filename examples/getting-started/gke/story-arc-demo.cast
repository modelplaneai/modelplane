[0.040, "o", " "]
[0.041, "o", "0"]
[0.036, "o", "2"]
[0.038, "o", "-"]
[0.041, "o", "s"]
[0.039, "o", "c"]
[0.039, "o", "a"]
[0.038, "o", "l"]
[0.038, "o", "e"]
[0.037, "o", "-"]
[0.040, "o", "t"]
[0.040, "o", "o"]
[0.041, "o", "-"]
[0.038, "o", "f"]
[0.036, "o", "l"]
[0.039, "o", "e"]
[0.036, "o", "e"]
[0.037, "o", "t"]
[0.040, "o", "."]
[0.039, "o", "y"]
[0.038, "o", "a"]
[0.039, "o", "m"]
[0.037, "o", "l"]
