[0.288, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.001, "o", "\r\n\u001b[2m# Modelplane separates two roles. The PLATFORM TEAM builds a GPU fleet with published hardware capabilities. The ML TEAM deploys models against those capabilities — by capability, never by cluster name.\u001b[0m\r\n"]
[2.004, "o", "\r\n\u001b[2m# The control plane is already running on kind: Crossplane, the Modelplane package, and GCP credentials.\u001b[0m\r\n"]
[2.010, "o", "\r\n\u001b[2m# Part 1 (first-deployment.md) — stand up the platform and serve one model.\u001b[0m\r\n"]
[2.011, "o", "\r\n\u001b[2m# PLATFORM TEAM installs the control-plane routing gateway. It runs Traefik (+ MetalLB on kind) so every ModelService gets one stable address:\u001b[0m\r\n"]
[2.010, "o", "\u001b[1;32m$ \u001b[0m\u001b[1m"]
