[0.515, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: ModelDeployment\r\nmetadata:\r\n  name: qwen-demo\r\n  namespace: ml-team\r\nspec:\r\n  replicas: 1\r\n  engines:\r\n  - name: qwen\r\n    members:\r\n    - role: Standalone\r\n      nodeSelector:\r\n        devices:\r\n        - name: gpu\r\n          count: 1\r\n          selectors:\r\n          - cel: |\r\n              device.capacity[\"gpu.nvidia.com\"].memory.compareTo(quantity(\"20Gi\")) >= 0\r\n      template:\r\n        spec:\r\n          containers:\r\n          - name: engine\r\n            image: vllm/vllm-openai:v0.11.0\r\n            args:\r\n            - --model=Qwen/Qwen2.5-0.5B-Instruct\r\n            - --dtype=half\r\n---\r\n"]
[0.000, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: ModelService\r\nmetadata:\r\n  name: qwen\r\n  namespace: ml-team\r\nspec:\r\n  endpoints:\r\n  - selector:\r\n      matchLabels:\r\n"]
[0.000, "o", "        modelplane.ai/deployment: qwen-demo\r\n"]
[0.000, "o", "---\r\n"]
