[0.519, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: ModelDeployment\r\nmetadata:\r\n  name: qwen-demo\r\n  namespace: ml-team\r\nspec:\r\n  replicas: 2\r\n  engines:\r\n  - name: qwen\r\n    members:\r\n    - role: Standalone\r\n      nodeSelector:\r\n        devices:\r\n"]
[0.000, "o", "        - name: gpu\r\n          count: 1\r\n          selectors:\r\n          - cel: |\r\n              device.capacity[\"gpu.nvidia.com\"].memory.compareTo(quantity(\"35Gi\")) >= 0\r\n      template:\r\n        spec:\r\n          containers:\r\n          - name: engine\r\n            image: vllm/vllm-openai:v0.11.0\r\n            args:\r\n            - --model=Qwen/Qwen2.5-0.5B-Instruct\r\n            - --dtype=half\r\n---\r\n"]
