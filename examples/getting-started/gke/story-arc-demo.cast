[0.558, "o", "NAME          SOURCE   GATEWAY        SYNCED   READY   COMPOSITION                       AGE    REGION\r\ngpu-us-east   GKE                     True     False   inferenceclusters.modelplane.ai   84m    us-east\r\ngpu-us-west"]
