[0.039, "o", "\u001b[0m\r\n"]
[0.513, "o", "# The in-place edit: same model, same name, same ModelService — only the replica\r\n# count and the capability selector change. Re-applying qwen-demo moves it off\r\n# the L4 and onto the two A100 clusters.\r\napiVersion: modelplane.ai/v1alpha1\r\nkind: ModelDeployment\r\nmetadata:\r\n  name: qwen-demo\r\n  namespace: ml-team\r\nspec:\r\n  replicas: 2                       # one per A100 cluster\r\n  engines:\r\n  - name: qwen\r\n    members:\r\n    - role: Standalone\r\n      nodeSelector:\r\n        devices:\r\n        - name: gpu\r\n          count: 1\r\n          selectors:\r\n          # \"Give me a GPU with >= 35 GB.\" Only the A100 clusters qualify; the L4\r\n          # starter (24 GB) is skipped — across regions, with no cluster name.\r\n          - cel: |\r\n              device.capacity[\"gpu.nvidia.com\"].memory.compareTo(quantity(\"35Gi\")) >= 0\r\n      template:\r\n        spec:\r\n          containers:\r\n          - name: engine\r\n"]
[0.000, "o", "            image: vllm/vllm-openai:v0.11.0\r\n            args:\r\n            - --model=Qwen/Qwen2.5-0.5B-Instruct\r\n            - --dtype=half\r\n---\r\n"]
[5.007, "o", "\u001b[1;32m$ \u001b[0m\u001b[1mk"]
