[0.000, "o", "\r\n\u001b[2m# Platform team — publish the GPU hardware (InferenceClass) and provision a starter cluster.\u001b[0m\r\n"]
[2.005, "o", "\u001b[1;32m$ \u001b[0m\u001b[1mc"]
