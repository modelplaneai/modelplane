[0.519, "o", "# The control plane routing gateway. Installs Traefik Proxy and MetalLB\r\n# (for kind clusters). On cloud clusters, omit the loadBalancer/metallb\r\n# fields — the cloud LB controller handles address assignment.\r\napiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceGateway\r\nmetadata:\r\n  name: default\r\nspec:\r\n  backend: Traefik\r\n  traefik:\r\n    version: \"40.2.0\"\r\n    loadBalancer: MetalLB\r\n    metallb:\r\n      addressPool: \"172.18.255.200-172.18.255.250\"\r\n"]
