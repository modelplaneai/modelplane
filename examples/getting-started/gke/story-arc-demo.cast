[0.039, "o", "\u001b[0m\r\n"]
[0.513, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceClass\r\nmetadata:\r\n  name: gke-a100-40-1x\r\nspec:\r\n  description: \"GKE a2-highgpu-1g, 1x NVIDIA A100 40GB (the powerful workload GPU)\"\r\n  provisioning:\r\n    provider: GKE\r\n    gke:\r\n      machineType: a2-highgpu-1g\r\n      diskSizeGb: 200\r\n      accelerator:\r\n        type: nvidia-tesla-a100\r\n        count: 1\r\n  devices:\r\n  - name: gpu\r\n    claim: DRA\r\n    driver: gpu.nvidia.com\r\n    deviceClassName: gpu.nvidia.com\r\n"]
[0.000, "o", "    count: 1\r\n    attributes:\r\n      architecture: { string: Ampere }\r\n      cudaComputeCapability: { version: \"8.0.0\" }\r\n    capacity:\r\n      # A100 40GB real reported VRAM (verify against a live ResourceSlice). The\r\n      # selector threshold must sit below it.\r\n      memory: { value: \"40960Mi\" }\r\n---\r\n"]
[0.000, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceCluster\r\nmetadata:\r\n  name: gpu-us-west\r\n  labels:\r\n    modelplane.ai/region: us-west\r\nspec:\r\n  cluster:\r\n    source: GKE\r\n    gke:\r\n      project: crossplane-playground\r\n      region: us-west1\r\n  nodePools:\r\n  - name: gpu-a100\r\n"]
[0.000, "o", "    className: gke-a100-40-1x\r\n    nodeCount: 1\r\n    minNodeCount: 1   # keep >=1: the cluster autoscaler can't scale a GPU pool\r\n"]
[0.000, "o", "    maxNodeCount: 2   # up from 0 for DRA ResourceClaim pods (\"cannot allocate all claims\")\r\n"]
[0.000, "o", "    zones:\r\n"]
[0.000, "o", "    - us-west1-b\r\n"]
[0.000, "o", "---\r\n"]
[0.000, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceCluster\r\nmetadata:\r\n  name: gpu-us-east\r\n  labels:\r\n    modelplane.ai/region: us-east\r\nspec:\r\n"]
[0.000, "o", "  cluster:\r\n    source: GKE\r\n"]
[0.000, "o", "    gke:\r\n"]
[0.000, "o", "      project: crossplane-playground\r\n"]
[0.000, "o", "      region: us-east1\r\n  nodePools:\r\n"]
[0.000, "o", "  - name: gpu-a100\r\n"]
[0.000, "o", "    className: gke-a100-40-1x\r\n"]
[0.000, "o", "    nodeCount: 1\r\n"]
[0.000, "o", "    minNodeCount: 1   # keep >=1: the cluster autoscaler can't scale a GPU pool\r\n"]
[0.000, "o", "    maxNodeCount: 2   # up from 0 for DRA ResourceClaim pods (\"cannot allocate all claims\")\r\n"]
[0.000, "o", "    zones:\r\n"]
[0.000, "o", "    - us-east1-b\r\n"]
[0.000, "o", "---\r\n"]
