[0.039, "o", "e"]
[0.038, "o", "n"]
[0.039, "o", "c"]
[0.038, "o", "e"]
[0.040, "o", "C"]
[0.040, "o", "l"]
[0.040, "o", "a"]
[0.040, "o", "s"]
[0.036, "o", "s"]
[0.038, "o", "|"]
[0.035, "o", "I"]
[0.039, "o", "n"]
[0.039, "o", "f"]
[0.036, "o", "e"]
[0.040, "o", "r"]
[0.037, "o", "e"]
[0.037, "o", "n"]
[0.037, "o", "c"]
[0.039, "o", "e"]
[0.035, "o", "C"]
[0.037, "o", "l"]
[0.036, "o", "u"]
[0.037, "o", "s"]
[0.037, "o", "t"]
[0.040, "o", "e"]
[0.036, "o", "r"]
[0.040, "o", "'"]
[0.040, "o", "\u001b[0m\r\n"]
[0.514, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceClass\r\nmetadata:\r\n  name: gke-a100-40-1x\r\nspec:\r\n  description: \"GKE a2-highgpu-1g, 1x NVIDIA A100 40GB (the powerful workload GPU)\"\r\n  provisioning:\r\n    provider: GKE\r\n    gke:\r\n      machineType: a2-highgpu-1g\r\n      diskSizeGb: 200\r\n      accelerator:\r\n        type: nvidia-tesla-a100\r\n        count: 1\r\n  devices:\r\n  - name: gpu\r\n    claim: DRA\r\n    driver: gpu.nvidia.com\r\n    deviceClassName: gpu.nvidia.com\r\n    count: 1\r\n    attributes:\r\n      architecture: { string: Ampere }\r\n      cudaComputeCapability: { version: \"8.0.0\" }\r\n    capacity:\r\n      memory: { value: \"40960Mi\" }\r\n---\r\n"]
[0.000, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceCluster\r\nmetadata:\r\n  name: gpu-us-west\r\n  labels:\r\n    modelplane.ai/region: us-west\r\nspec:\r\n  cluster:\r\n    source: GKE\r\n    gke:\r\n      project: crossplane-playground\r\n      region: us-west1\r\n  nodePools:\r\n  - name: gpu-a100\r\n    className: gke-a100-40-1x\r\n"]
[0.000, "o", "    nodeCount: 1\r\n    minNodeCount: 1\r\n    maxNodeCount: 2\r\n    zones:\r\n    - us-west1-b\r\n---\r\n"]
[0.000, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceCluster\r\nmetadata:\r\n  name: gpu-us-east\r\n  labels:\r\n    modelplane.ai/region: us-east\r\nspec:\r\n  cluster:\r\n    source: GKE\r\n    gke:\r\n      project: crossplane-playground\r\n      region: us-east1\r\n  nodePools:\r\n  - name: gpu-a100\r\n    className: gke-a100-40-1x\r\n    nodeCount: 1\r\n"]
[0.000, "o", "    minNodeCount: 1\r\n    maxNodeCount: 2\r\n    zones:\r\n    - us-east1-b\r\n---\r\n"]
[5.011, "o", "\r\n\u001b[2m# The fleet now spans three regions, alongside the Part-1 L4 starter:\u001b[0m\r\n"]
[2.008, "o", "\u001b[1;32m$ \u001b[0m\u001b[1m"]
