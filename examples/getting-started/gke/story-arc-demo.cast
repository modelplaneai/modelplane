[0.516, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceClass\r\nmetadata:\r\n  name: gke-l4-1x-g2\r\nspec:\r\n  description: \"GKE g2-standard-8, 1x NVIDIA L4 (the cheap starter GPU)\"\r\n  provisioning:\r\n    provider: GKE\r\n    gke:\r\n      machineType: g2-standard-8\r\n      diskSizeGb: 100\r\n      accelerator:\r\n        type: nvidia-l4\r\n        count: 1\r\n  devices:\r\n  - name: gpu\r\n    claim: DRA\r\n    driver: gpu.nvidia.com\r\n    deviceClassName: gpu.nvidia.com\r\n    count: 1\r\n    attributes:\r\n      architecture: { string: Ada Lovelace }\r\n    capacity:\r\n      memory: { value: \"23034Mi\" }\r\n---\r\n"]
[0.000, "o", "apiVersion: modelplane.ai/v1alpha1\r\nkind: InferenceCluster\r\nmetadata:\r\n  name: starter\r\n  labels:\r\n    modelplane.ai/region: us-central\r\nspec:\r\n  cluster:\r\n    source: GKE\r\n    gke:\r\n"]
[0.000, "o", "      project: crossplane-playground\r\n      region: us-central1\r\n"]
[0.000, "o", "  nodePools:\r\n  - name: gpu-l4\r\n    className: gke-l4-1x-g2\r\n    nodeCount: 1\r\n    minNodeCount: 1\r\n    maxNodeCount: 2\r\n    zones:\r\n    - us-central1-a\r\n---\r\n"]
