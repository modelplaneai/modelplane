[0.000, "o", "True     True    inferenceclusters.modelplane.ai   119m   us-central\r\n"]
[6.011, "o", "\r\n\u001b[2m# ML team adds a second deployment, pinned to us-west, asking for a bigger GPU.\u001b[0m\r\n"]
